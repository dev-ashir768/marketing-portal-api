    "express-rate-limit": "^8.5.2",
    "facebook-nodejs-business-sdk": "^21.0.3",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "zod": "^3.23.8"
