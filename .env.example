NODE_ENV=development
PORT=4000

# MySQL connection string for Prisma
DATABASE_URL="mysql://marketing_portal_admin:Programmer@2026@localhost:3306/marketing_portal"

# Generate with: openssl rand -hex 32 (must be >= 32 chars)
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# 32-byte AES-256-GCM key, hex-encoded (64 chars). Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=replace-with-64-char-hex-string

# NOTE: there is no platform-wide META_APP_ID/SECRET here. Each user registers
# their own Meta Developer App via POST /api/v1/meta-apps (stored encrypted in
# the MetaApp table), and OAuth connects run under that app's identity.
META_API_VERSION=v21.0

# Meta Webhook verify token — apna koi bhi random string rakho
# Meta Developer App > Webhooks > Edit Subscription mein bhi yahi dalo
META_WEBHOOK_VERIFY_TOKEN=replace-with-random-string

# Single shared callback — every user must add this exact URL to their own
# Meta App's "Valid OAuth Redirect URIs" list (Facebook Login for Business settings).
META_OAUTH_REDIRECT_URI=http://localhost:4000/api/v1/meta-accounts/oauth/callback

# Fallback only — used when a client hasn't set their own User.portalUrl yet
# (each white-labeled client normally has their own portal/frontend domain).
FRONTEND_URL=http://localhost:3000

# Comma-separated extra CORS origins (e.g. an internal admin dashboard).
# Each client's own User.portalUrl is allowed automatically — no need to list those here.
ALLOWED_ORIGINS=

# Optional — only activates error monitoring if set. Leave blank to disable.
SENTRY_DSN=
