generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  MEMBER
}

enum CampaignStatus {
  ACTIVE
  PAUSED
  DELETED
  ARCHIVED
  DRAFT
}

enum CampaignObjective {
  AWARENESS
  TRAFFIC
  ENGAGEMENT
  LEADS
  APP_PROMOTION
  SALES
}

// Tenant-owning user. Each user belongs to exactly one tenant in this MVP;
// swap to a separate Tenant model + UserTenant join table if multi-membership is needed later.
model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String
  name          String
  role          Role     @default(OWNER)
  // This client's own portal/frontend base URL. OAuth callbacks redirect here
  // instead of a single platform-wide frontend, since each client is white-labeled
  // with their own portal. Falls back to env FRONTEND_URL if unset.
  portalUrl     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  metaAccounts  MetaAccount[]
  metaApps      MetaApp[]

  @@map("users")
}

// A user-owned Meta Developer App ("Bring Your Own App"). Each user/agency registers
// their own App ID + App Secret here; OAuth connections are then performed under that
// app's identity rather than a single platform-wide app. appSecret is AES-256-GCM
// encrypted at rest — never stored or returned in plaintext.
model MetaApp {
  id                 String   @id @default(uuid())
  userId             String
  label              String? // optional friendly name, e.g. "Acme Agency App"
  appId              String   @unique // Meta's numeric App ID

  appSecretEncrypted String @db.Text
  appSecretIv        String
  appSecretAuthTag   String

  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  metaAccounts       MetaAccount[]

  @@index([userId])
  @@map("meta_apps")
}

// Stores the connection to a Meta Business/Ad account.
// accessToken/refreshToken are persisted as AES-256-GCM ciphertext (see src/utils/crypto.ts),
// never in plaintext — iv/authTag are required to decrypt.
model MetaAccount {
  id              String   @id @default(uuid())
  userId          String
  metaAppId       String? // which user-owned Meta App this token/account was obtained through
  metaAdAccountId String   @unique // Meta's act_<id> identifier
  facebookUserId  String?  // the Meta/Facebook user id that authorized this connection — needed to match deauthorize webhook callbacks
  businessName    String?

  accessTokenEncrypted String @db.Text
  accessTokenIv        String
  accessTokenAuthTag   String

  refreshTokenEncrypted String? @db.Text
  refreshTokenIv        String?
  refreshTokenAuthTag   String?

  tokenExpiresAt  DateTime?
  isActive        Boolean  @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  metaApp         MetaApp?      @relation(fields: [metaAppId], references: [id], onDelete: SetNull)
  campaigns       AdCampaign[]

  @@index([userId])
  @@index([metaAppId])
  @@index([facebookUserId])
  @@map("meta_accounts")
}

model AdCampaign {
  id              String            @id @default(uuid())
  metaAccountId   String
  metaCampaignId  String?           @unique // populated once synced/created on Meta
  name            String
  objective       CampaignObjective
  status          CampaignStatus    @default(DRAFT)
  dailyBudgetCents Int?
  lifetimeBudgetCents Int?
  startTime       DateTime?
  endTime         DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  metaAccount     MetaAccount @relation(fields: [metaAccountId], references: [id], onDelete: Cascade)

  @@index([metaAccountId])
  @@map("ad_campaigns")
}
