generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  MEMBER
}

enum CampaignStatus {
  ACTIVE
  PAUSED
  DELETED
  ARCHIVED
  DRAFT
}

enum CampaignObjective {
  OUTCOME_AWARENESS
  OUTCOME_TRAFFIC
  OUTCOME_ENGAGEMENT
  OUTCOME_LEADS
  OUTCOME_APP_PROMOTION
  OUTCOME_SALES
}

enum AdSetStatus {
  ACTIVE
  PAUSED
  DELETED
  ARCHIVED
}

enum AdStatus {
  ACTIVE
  PAUSED
  DELETED
  ARCHIVED
}

enum CreativeMediaType {
  IMAGE
  VIDEO
}

model User {
  id           String  @id @default(uuid())
  email        String  @unique
  passwordHash String
  name         String
  role         Role    @default(OWNER)
  portalUrl    String?
  apiKeyPrefix String? @unique
  apiKeyHash   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  metaAccounts MetaAccount[]
  metaApps     MetaApp[]

  @@map("users")
}

model MetaApp {
  id     String  @id @default(uuid())
  userId String
  label  String?
  appId  String  @unique

  appSecretEncrypted String @db.Text
  appSecretIv        String
  appSecretAuthTag   String

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  metaAccounts MetaAccount[]

  @@index([userId])
  @@map("meta_apps")
}

model MetaAccount {
  id                 String  @id @default(uuid())
  userId             String
  metaAppId          String?
  metaAdAccountId    String  @unique
  facebookUserId     String?
  businessName       String?
  externalCustomerId String?

  accessTokenEncrypted String   @db.Text
  accessTokenIv        String
  accessTokenAuthTag   String

  tokenExpiresAt DateTime?
  isActive       Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  metaApp   MetaApp?     @relation(fields: [metaAppId], references: [id], onDelete: SetNull)
  campaigns AdCampaign[]
  adSets    AdSet[]
  ads       Ad[]
  creatives AdCreative[]

  @@index([userId])
  @@index([metaAppId])
  @@index([facebookUserId])
  @@index([externalCustomerId])
  @@map("meta_accounts")
}

model AdCampaign {
  id                  String            @id @default(uuid())
  metaAccountId       String
  metaCampaignId      String?           @unique
  name                String
  objective           CampaignObjective
  status              CampaignStatus    @default(DRAFT)
  dailyBudgetCents    Int?
  lifetimeBudgetCents Int?
  startTime           DateTime?
  endTime             DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  metaAccount MetaAccount @relation(fields: [metaAccountId], references: [id], onDelete: Cascade)
  adSets      AdSet[]

  @@index([metaAccountId])
  @@map("ad_campaigns")
}

model AdSet {
  id                  String      @id @default(uuid())
  metaAccountId       String
  campaignId          String
  metaAdSetId         String?     @unique
  name                String
  status              AdSetStatus @default(PAUSED)
  dailyBudgetCents    Int?
  lifetimeBudgetCents Int?
  startTime           DateTime?
  endTime             DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  metaAccount MetaAccount @relation(fields: [metaAccountId], references: [id], onDelete: Cascade)
  campaign    AdCampaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  ads         Ad[]

  @@index([metaAccountId])
  @@index([campaignId])
  @@map("ad_sets")
}

model Ad {
  id            String   @id @default(uuid())
  metaAccountId String
  adSetId       String
  metaAdId      String?  @unique
  name          String
  status        AdStatus @default(PAUSED)
  creativeId    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  metaAccount MetaAccount @relation(fields: [metaAccountId], references: [id], onDelete: Cascade)
  adSet       AdSet       @relation(fields: [adSetId], references: [id], onDelete: Cascade)
  creative    AdCreative? @relation(fields: [creativeId], references: [id], onDelete: SetNull)

  @@index([metaAccountId])
  @@index([adSetId])
  @@map("ads")
}

// Stores uploaded image/video reference after uploading to Meta.
// imageHash (for images) or videoId (for videos) is what Meta needs
// when creating an AdCreative or Ad.
model AdCreative {
  id              String            @id @default(uuid())
  metaAccountId   String
  metaCreativeId  String?           @unique // Meta's creative ID (after createAdCreative)
  mediaType       CreativeMediaType
  // For images: Meta returns an image_hash
  imageHash       String?
  // For videos: Meta returns a video_id
  videoId         String?
  // Ad copy
  headline        String?
  body            String?           @db.Text
  callToAction    String?           // e.g. "SHOP_NOW", "LEARN_MORE", "SIGN_UP"
  linkUrl         String?           @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  metaAccount MetaAccount @relation(fields: [metaAccountId], references: [id], onDelete: Cascade)
  ads         Ad[]

  @@index([metaAccountId])
  @@map("ad_creatives")
}
