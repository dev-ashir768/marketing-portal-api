{
  "info": {
    "name": "Marketing Portal - Meta Ads SaaS API",
    "description": "Two folders: Admin (platform owner setup) and Client (OMS integration flow).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://marketing.getorio.com/api/v1" },
    { "key": "serverUrl", "value": "https://marketing.getorio.com" },
    { "key": "token", "value": "" },
    { "key": "apiKey", "value": "" },
    { "key": "metaAppId", "value": "" },
    { "key": "metaAccountId", "value": "", "description": "Internal UUID — List Meta Accounts chalane par auto-set hota hai" },
    { "key": "metaAdAccountId", "value": "", "description": "Meta ka act_xxx ID — List Meta Accounts chalane par auto-set hota hai" },
    { "key": "campaignId", "value": "" },
    { "key": "adSetId", "value": "" },
    { "key": "adId", "value": "" },
    { "key": "externalCustomerId", "value": "customer-123" }
  ],
  "item": [
    {
      "name": "🔐 Admin",
      "description": "Platform owner (Ashir) ka area. Ek baar setup karo, phir sirf API key se kaam chalta hai.",
      "item": [
        {
          "name": "Register Account (ek baar)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"info@getorio.com\",\n  \"password\": \"SuperSecret!@2022\",\n  \"name\": \"Orio Admin\",\n  \"portalUrl\": \"https://oms.getorio.com\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('token', pm.response.json().data.token);",
                  "  console.log('Registered. Now run: Generate API Key');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login (token refresh karo)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"info@getorio.com\",\n  \"password\": \"SuperSecret!@2022\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  pm.collectionVariables.set('token', pm.response.json().data.token);",
                  "  console.log('Token saved. Now run: Generate API Key');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Generate API Key (ek baar — JWT se)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/auth/api-key", "host": ["{{baseUrl}}"], "path": ["auth", "api-key"] },
            "description": "Sirf ek baar chalao. Key {{apiKey}} mein save ho jati hai. Uske baad JWT ki zaroorat nahi."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const key = pm.response.json().data.apiKey;",
                  "  pm.collectionVariables.set('apiKey', key);",
                  "  console.log('API Key saved! Ab X-API-Key use karo sab jagah.');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Revoke API Key",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/auth/api-key", "host": ["{{baseUrl}}"], "path": ["auth", "api-key"] }
          }
        },
        {
          "name": "Update Portal URL",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-API-Key", "value": "{{apiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"portalUrl\": \"https://oms.getorio.com\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] }
          }
        },
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": { "raw": "{{serverUrl}}/health", "host": ["{{serverUrl}}"], "path": ["health"] }
          }
        }
      ]
    },
    {
      "name": "🏢 Client (OMS)",
      "description": "OMS ya external system ka flow. Sirf X-API-Key use hoti hai — JWT nahi.",
      "item": [
        {
          "name": "Meta Apps",
          "item": [
            {
              "name": "Register Meta App (client ki apni app)",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "X-API-Key", "value": "{{apiKey}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"appId\": \"1234567890123456\",\n  \"appSecret\": \"client-ka-real-meta-app-secret\",\n  \"label\": \"Client Ka Meta App\"\n}"
                },
                "url": { "raw": "{{baseUrl}}/meta-apps", "host": ["{{baseUrl}}"], "path": ["meta-apps"] },
                "description": "Har client ke liye ek baar. Real App ID + Secret dalo — server Meta se verify karta hai."
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "if (pm.response.code === 201) {",
                      "  pm.collectionVariables.set('metaAppId', pm.response.json().data.id);",
                      "  console.log('metaAppId saved!');",
                      "}"
                    ]
                  }
                }
              ]
            },
            {
              "name": "List Meta Apps",
              "request": {
                "method": "GET",
                "header": [{ "key": "X-API-Key", "value": "{{apiKey}}" }],
                "url": { "raw": "{{baseUrl}}/meta-apps", "host": ["{{baseUrl}}"], "path": ["meta-apps"] }
              }
            }
          ]
        },
        {
          "name": "Meta Accounts",
          "item": [
            {
              "name": "Start OAuth (customer ka Meta connect)",
              "request": {
                "method": "GET",
                "header": [{ "key": "X-API-Key", "value": "{{apiKey}}" }],
                "url": {
                  "raw": "{{baseUrl}}/meta-accounts/oauth/start?metaAppId={{metaAppId}}&externalCustomerId={{externalCustomerId}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["meta-accounts", "oauth", "start"],
                  "query": [
                    { "key": "metaAppId", "value": "{{metaAppId}}" },
                    { "key": "externalCustomerId", "value": "{{externalCustomerId}}", "description": "OMS ka apna customer ID" }
                  ]
                },
                "description": "Response mein redirect URL milega — wo URL browser mein kholo. Customer Meta login karega. Callback automatic hoga."
              }
            },
            {
              "name": "Connect Meta Account (manual token — testing only)",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "X-API-Key", "value": "{{apiKey}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"metaAdAccountId\": \"act_123456789\",\n  \"businessName\": \"Acme Inc\",\n  \"accessToken\": \"EAAB...longLivedToken\",\n  \"tokenExpiresAt\": \"2026-12-31T00:00:00.000Z\",\n  \"externalCustomerId\": \"{{externalCustomerId}}\"\n}"
                },
                "url": { "raw": "{{baseUrl}}/meta-accounts", "host": ["{{baseUrl}}"], "path": ["meta-accounts"] }
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "if (pm.response.code === 201) {",
                      "  pm.collectionVariables.set('metaAccountId', pm.response.json().data.id);",
                      "}"
                    ]
                  }
                }
              ]
            },
            {
              "name": "List Meta Accounts (saare)",
              "request": {
                "method": "GET",
                "header": [{ "key": "X-API-Key", "value": "{{apiKey}}" }],
                "url": { "raw": "{{baseUrl}}/meta-accounts", "host": ["{{baseUrl}}"], "path": ["meta-accounts"] },
                "description": "Sab connected Meta accounts. Response mein:\n- id = metaAccountId (internal UUID, Campaigns mein use karo)\n- metaAdAccountId = act_xxx (Meta ka ID, sync mein directly bhi use kar sakte ho)"
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "const res = pm.response.json();",
                      "if (res.success && res.data && res.data.length > 0) {",
                      "  const first = res.data[0];",
                      "  pm.collectionVariables.set('metaAccountId', first.id);",
                      "  pm.collectionVariables.set('metaAdAccountId', first.metaAdAccountId);",
                      "  console.log('✅ metaAccountId (UUID):', first.id);",
                      "  console.log('✅ metaAdAccountId (act_xxx):', first.metaAdAccountId);",
                      "}"
                    ]
                  }
                }
              ]
            },
            {
              "name": "List Meta Accounts (ek customer ke)",
              "request": {
                "method": "GET",
                "header": [{ "key": "X-API-Key", "value": "{{apiKey}}" }],
                "url": {
                  "raw": "{{baseUrl}}/meta-accounts?externalCustomerId={{externalCustomerId}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["meta-accounts"],
                  "query": [{ "key": "externalCustomerId", "value": "{{externalCustomerId}}" }]
                }
              }
            },
            {
              "name": "Deauthorize Webhook (Meta calls this)",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
                "body": {
                  "mode": "urlencoded",
                  "urlencoded": [{ "key": "signed_request", "value": "<base64url-sig>.<base64url-payload>" }]
                },
                "url": {
                  "raw": "{{baseUrl}}/meta-accounts/webhook/deauthorize/{{metaAppId}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["meta-accounts", "webhook", "deauthorize", "{{metaAppId}}"]
                },
                "description": "Meta khud call karta hai jab user revoke karta hai. Manual call signature check mein fail hogi."
              }
            }
          ]
        },
        {
          "name": "Campaigns",
          "item": [
            {
              "name": "Sync Campaigns from Meta",
              "request": {
                "method": "POST",
                "header": [{ "key": "X-API-Key", "value": "{{apiKey}}" }],
                "url": {
                  "raw": "{{baseUrl}}/campaigns/sync?externalCustomerId={{externalCustomerId}}&metaAdAccountId={{metaAdAccountId}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["campaigns", "sync"],
                  "query": [
                    { "key": "externalCustomerId", "value": "{{externalCustomerId}}", "description": "Customer ka ID (e.g. OR-1001) — sirf isi customer ka account sync hoga" },
                    { "key": "metaAdAccountId", "value": "{{metaAdAccountId}}", "description": "Meta ka act_xxx ID (e.g. act_221314300585657)" }
                  ]
                },
                "description": "Customer ki Meta campaigns DB mein sync karta hai.\n- externalCustomerId: OMS customer ID (OR-1001)\n- metaAdAccountId: Meta act_xxx\nServer har 30 min automatic bhi karta hai."
              }
            },
            {
              "name": "Create Campaign",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "X-API-Key", "value": "{{apiKey}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"metaAccountId\": \"{{metaAccountId}}\",\n  \"externalCustomerId\": \"{{externalCustomerId}}\",\n  \"name\": \"Summer Sale Campaign\",\n  \"objective\": \"OUTCOME_SALES\",\n  \"status\": \"DRAFT\",\n  \"dailyBudgetCents\": 5000\n}"
                },
                "url": { "raw": "{{baseUrl}}/campaigns", "host": ["{{baseUrl}}"], "path": ["campaigns"] },
                "description": "externalCustomerId pass karo — verify hoga ke metaAccountId usi customer ka hai."
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "if (pm.response.code === 201) {",
                      "  pm.collectionVariables.set('campaignId', pm.response.json().data.id);",
                      "}"
                    ]
                  }
                }
              ]
            },
            {
              "name": "List Campaigns (customer ke saare)",
              "request": {
                "method": "GET",
                "header": [{ "key": "X-API-Key", "value": "{{apiKey}}" }],
                "url": {
                  "raw": "{{baseUrl}}/campaigns?externalCustomerId={{externalCustomerId}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["campaigns"],
                  "query": [
                    { "key": "externalCustomerId", "value": "{{externalCustomerId}}", "description": "Sirf isi customer ke campaigns" }
                  ]
                },
                "description": "Customer ke saare campaigns (saare Meta accounts across). externalCustomerId required."
              }
            },
            {
              "name": "List Campaigns (ek act_xxx ke)",
              "request": {
                "method": "GET",
                "header": [{ "key": "X-API-Key", "value": "{{apiKey}}" }],
                "url": {
                  "raw": "{{baseUrl}}/campaigns?externalCustomerId={{externalCustomerId}}&metaAdAccountId={{metaAdAccountId}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["campaigns"],
                  "query": [
                    { "key": "externalCustomerId", "value": "{{externalCustomerId}}" },
                    { "key": "metaAdAccountId", "value": "{{metaAdAccountId}}", "description": "Specific act_xxx filter" }
                  ]
                }
              }
            },
            {
              "name": "Get Campaign",
              "request": {
                "method": "GET",
                "header": [{ "key": "X-API-Key", "value": "{{apiKey}}" }],
                "url": {
                  "raw": "{{baseUrl}}/campaigns/{{campaignId}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["campaigns", "{{campaignId}}"]
                }
              }
            },
            {
              "name": "Update Campaign",
              "request": {
                "method": "PATCH",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "X-API-Key", "value": "{{apiKey}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"status\": \"ACTIVE\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/campaigns/{{campaignId}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["campaigns", "{{campaignId}}"]
                }
              }
            },
            {
              "name": "Delete Campaign",
              "request": {
                "method": "DELETE",
                "header": [{ "key": "X-API-Key", "value": "{{apiKey}}" }],
                "url": {
                  "raw": "{{baseUrl}}/campaigns/{{campaignId}}?externalCustomerId={{externalCustomerId}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["campaigns", "{{campaignId}}"],
                  "query": [{ "key": "externalCustomerId", "value": "{{externalCustomerId}}" }]
                }
              }
            }
          ]
        },
        {
          "name": "Ad Sets",
          "item": [
            {
              "name": "Sync Ad Sets (campaign ke andar)",
              "request": {
                "method": "POST",
                "header": [{ "key": "X-API-Key", "value": "{{apiKey}}" }],
                "url": {
                  "raw": "{{baseUrl}}/campaigns/{{campaignId}}/ad-sets/sync?externalCustomerId={{externalCustomerId}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["campaigns", "{{campaignId}}", "ad-sets", "sync"],
                  "query": [{ "key": "externalCustomerId", "value": "{{externalCustomerId}}" }]
                },
                "description": "Campaign ke andar saare Ad Sets Meta se sync karo."
              },
              "event": [{ "listen": "test", "script": { "exec": ["console.log('Ad Sets synced:', pm.response.json());"] } }]
            },
            {
              "name": "List Ad Sets",
              "request": {
                "method": "GET",
                "header": [{ "key": "X-API-Key", "value": "{{apiKey}}" }],
                "url": {
                  "raw": "{{baseUrl}}/campaigns/{{campaignId}}/ad-sets?externalCustomerId={{externalCustomerId}}&page=1&limit=20",
                  "host": ["{{baseUrl}}"],
                  "path": ["campaigns", "{{campaignId}}", "ad-sets"],
                  "query": [
                    { "key": "externalCustomerId", "value": "{{externalCustomerId}}" },
                    { "key": "page", "value": "1" },
                    { "key": "limit", "value": "20" }
                  ]
                }
              },
              "event": [{
                "listen": "test",
                "script": { "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data && res.data.length > 0) {",
                  "  pm.collectionVariables.set('adSetId', res.data[0].id);",
                  "  console.log('adSetId set:', res.data[0].id);",
                  "}"
                ]}
              }]
            },
            {
              "name": "Get Ad Set",
              "request": {
                "method": "GET",
                "header": [{ "key": "X-API-Key", "value": "{{apiKey}}" }],
                "url": {
                  "raw": "{{baseUrl}}/campaigns/{{campaignId}}/ad-sets/{{adSetId}}?externalCustomerId={{externalCustomerId}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["campaigns", "{{campaignId}}", "ad-sets", "{{adSetId}}"],
                  "query": [{ "key": "externalCustomerId", "value": "{{externalCustomerId}}" }]
                }
              }
            },
            {
              "name": "Update Ad Set",
              "request": {
                "method": "PATCH",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "X-API-Key", "value": "{{apiKey}}" }
                ],
                "body": { "mode": "raw", "raw": "{\n  \"status\": \"PAUSED\"\n}" },
                "url": {
                  "raw": "{{baseUrl}}/campaigns/{{campaignId}}/ad-sets/{{adSetId}}?externalCustomerId={{externalCustomerId}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["campaigns", "{{campaignId}}", "ad-sets", "{{adSetId}}"],
                  "query": [{ "key": "externalCustomerId", "value": "{{externalCustomerId}}" }]
                }
              }
            },
            {
              "name": "Delete Ad Set",
              "request": {
                "method": "DELETE",
                "header": [{ "key": "X-API-Key", "value": "{{apiKey}}" }],
                "url": {
                  "raw": "{{baseUrl}}/campaigns/{{campaignId}}/ad-sets/{{adSetId}}?externalCustomerId={{externalCustomerId}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["campaigns", "{{campaignId}}", "ad-sets", "{{adSetId}}"],
                  "query": [{ "key": "externalCustomerId", "value": "{{externalCustomerId}}" }]
                }
              }
            }
          ]
        },
        {
          "name": "Ads",
          "item": [
            {
              "name": "Sync Ads (ad set ke andar)",
              "request": {
                "method": "POST",
                "header": [{ "key": "X-API-Key", "value": "{{apiKey}}" }],
                "url": {
                  "raw": "{{baseUrl}}/campaigns/{{campaignId}}/ad-sets/{{adSetId}}/ads/sync?externalCustomerId={{externalCustomerId}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["campaigns", "{{campaignId}}", "ad-sets", "{{adSetId}}", "ads", "sync"],
                  "query": [{ "key": "externalCustomerId", "value": "{{externalCustomerId}}" }]
                },
                "description": "Ad Set ke andar saare Ads Meta se sync karo."
              }
            },
            {
              "name": "List Ads",
              "request": {
                "method": "GET",
                "header": [{ "key": "X-API-Key", "value": "{{apiKey}}" }],
                "url": {
                  "raw": "{{baseUrl}}/campaigns/{{campaignId}}/ad-sets/{{adSetId}}/ads?externalCustomerId={{externalCustomerId}}&page=1&limit=20",
                  "host": ["{{baseUrl}}"],
                  "path": ["campaigns", "{{campaignId}}", "ad-sets", "{{adSetId}}", "ads"],
                  "query": [
                    { "key": "externalCustomerId", "value": "{{externalCustomerId}}" },
                    { "key": "page", "value": "1" },
                    { "key": "limit", "value": "20" }
                  ]
                }
              },
              "event": [{
                "listen": "test",
                "script": { "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data && res.data.length > 0) {",
                  "  pm.collectionVariables.set('adId', res.data[0].id);",
                  "  console.log('adId set:', res.data[0].id);",
                  "}"
                ]}
              }]
            },
            {
              "name": "Get Ad",
              "request": {
                "method": "GET",
                "header": [{ "key": "X-API-Key", "value": "{{apiKey}}" }],
                "url": {
                  "raw": "{{baseUrl}}/campaigns/{{campaignId}}/ad-sets/{{adSetId}}/ads/{{adId}}?externalCustomerId={{externalCustomerId}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["campaigns", "{{campaignId}}", "ad-sets", "{{adSetId}}", "ads", "{{adId}}"],
                  "query": [{ "key": "externalCustomerId", "value": "{{externalCustomerId}}" }]
                }
              }
            },
            {
              "name": "Update Ad",
              "request": {
                "method": "PATCH",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "X-API-Key", "value": "{{apiKey}}" }
                ],
                "body": { "mode": "raw", "raw": "{\n  \"status\": \"PAUSED\"\n}" },
                "url": {
                  "raw": "{{baseUrl}}/campaigns/{{campaignId}}/ad-sets/{{adSetId}}/ads/{{adId}}?externalCustomerId={{externalCustomerId}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["campaigns", "{{campaignId}}", "ad-sets", "{{adSetId}}", "ads", "{{adId}}"],
                  "query": [{ "key": "externalCustomerId", "value": "{{externalCustomerId}}" }]
                }
              }
            },
            {
              "name": "Delete Ad",
              "request": {
                "method": "DELETE",
                "header": [{ "key": "X-API-Key", "value": "{{apiKey}}" }],
                "url": {
                  "raw": "{{baseUrl}}/campaigns/{{campaignId}}/ad-sets/{{adSetId}}/ads/{{adId}}?externalCustomerId={{externalCustomerId}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["campaigns", "{{campaignId}}", "ad-sets", "{{adSetId}}", "ads", "{{adId}}"],
                  "query": [{ "key": "externalCustomerId", "value": "{{externalCustomerId}}" }]
                }
              }
            }
          ]
        },
        {
          "name": "Insights & Reporting",
          "item": [
            {
              "name": "Account-level Insights",
              "request": {
                "method": "GET",
                "header": [{ "key": "X-API-Key", "value": "{{apiKey}}" }],
                "url": {
                  "raw": "{{baseUrl}}/insights?metaAdAccountId={{metaAdAccountId}}&externalCustomerId={{externalCustomerId}}&datePreset=last_30d",
                  "host": ["{{baseUrl}}"],
                  "path": ["insights"],
                  "query": [
                    { "key": "metaAdAccountId", "value": "{{metaAdAccountId}}", "description": "act_xxx" },
                    { "key": "externalCustomerId", "value": "{{externalCustomerId}}" },
                    { "key": "datePreset", "value": "last_30d", "description": "last_7d | last_30d | this_month | last_month" }
                  ]
                },
                "description": "Pura account ka spend, impressions, clicks, CTR, CPM."
              }
            },
            {
              "name": "Campaign-level Insights",
              "request": {
                "method": "GET",
                "header": [{ "key": "X-API-Key", "value": "{{apiKey}}" }],
                "url": {
                  "raw": "{{baseUrl}}/insights?metaCampaignId=&externalCustomerId={{externalCustomerId}}&datePreset=last_30d",
                  "host": ["{{baseUrl}}"],
                  "path": ["insights"],
                  "query": [
